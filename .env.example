# Irrigo environment variables.
#
# Copy this file to `.env` at the repo root and fill in the required values.
# Docker Compose loads `.env` from the directory containing the compose file.
# `.env` is gitignored.
#
# Every variable below is explicitly set — docker-compose.yml does not carry
# `${VAR:-default}` fallbacks. Sensible defaults are shown verbatim; empty
# required values and `change_me` placeholders are host-specific and must
# be replaced before the stack will boot correctly.

# --- Home Assistant (required) ---
# Base URL of your Home Assistant instance, e.g. http://192.168.2.100:8123.
# No trailing slash required (the client trims it).
HA_URL=

# Long-lived access token used to authenticate to the HA REST API.
# Mint one in HA: Profile (bottom-left) → Security tab → Long-Lived Access
# Tokens → Create Token. Treat this as a credential — do not commit it.
HA_TOKEN=

# --- Home Assistant (tuning) ---
# Base retry attempts for switch.turn_on calls. switch.turn_off doubles this
# automatically (closing a stuck-on relay matters more than opening one).
HA_RETRY_MAX=3

# Initial backoff (ms) between retry attempts; grows exponentially.
HA_RETRY_BASE_MS=1000

# --- Home Assistant notifications ---
# Name of the HA notify service to call (e.g. `mobile_app_pixel_8`,
# `persistent_notification`). Leave empty to disable all notifications
# regardless of the per-event flags below.
HA_NOTIFY_SERVICE=

# Per-event opt-in flags. Scheduled-run and error events default to on. The
# per-manual-fire watering events default to off (noisy if the operator runs
# zones from the HTTP surface frequently).
NOTIFY_ON_SCHEDULE_START=true
NOTIFY_ON_SCHEDULE_END=true
NOTIFY_ON_WATERING_START=false
NOTIFY_ON_WATERING_END=false
NOTIFY_ON_ERROR=true

# --- Open-Meteo (optional; consumed by API code, not docker-compose) ---
# Set to false to disable all weather API calls (e.g. offline dev, CI without
# network access). When disabled, runScheduleForZone will throw rather than
# fetch. Defaults to enabled when unset.
# OPEN_METEO_ENABLED=true

# Commercial API key from open-meteo.com. When set, requests are routed to
# customer-api.open-meteo.com (no rate limits) and `apikey` is appended to
# every request. Leave unset to use the free-tier endpoint.
# OPEN_METEO_API_KEY=

# --- Expo push notifications (optional) ---
# Server access token for Expo's push API. When set, requests to /push/send
# and /push/getReceipts include `Authorization: Bearer <token>` and Expo
# rejects unauthenticated calls — protects users whose push tokens leak from
# being targeted by third parties. Mint one at expo.dev → Account Settings →
# Access Tokens. Leave unset for dev; required in any production deploy.
EXPO_ACCESS_TOKEN=

# --- Postgres ---
# Used by the bundled `db` container. Change all three (and DATABASE_URL
# below) if you point the api at an external database instead.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=irrigation

# Connection string the api uses to reach Postgres. Must stay in sync with
# the POSTGRES_* values above unless pointing at an external database.
DATABASE_URL=postgresql://postgres:postgres@db:5432/irrigation

# --- API runtime ---
NODE_ENV=production
PORT=9753

# Set to true to plan and log irrigation cycles without sending any relay
# commands to Home Assistant. Useful for testing plan generation.
DRY_RUN=false

# --- Planner ---
# Forecast rain-skip lookahead, in days (starting tomorrow). Before committing
# a night's irrigation the planner sums the effective rainfall forecast over
# this many days; if that rain would by itself bring soil depletion back below
# the watering trigger, the night is deferred (standard smart-controller "rain
# delay"). The daemon re-plans every evening, so a skip is reconsidered the
# next day if the rain doesn't arrive. Set to 0 to disable the rain-skip.
RAIN_SKIP_LOOKAHEAD_DAYS=3

# Retention window (days) for persisted Open-Meteo weather snapshots. The
# daemon appends a forecast snapshot per zone on each successful fetch (for
# scheduling retrospectives) and prunes snapshots older than this many days on
# each write. Four weeks balances useful history against unbounded growth. Set
# to 0 to keep snapshots forever (disable pruning).
WEATHER_SNAPSHOT_RETENTION_DAYS=28

# --- VS Code Dev Container ---
# UID/GID inside the container must match your host user so bind-mounted
# files retain the correct ownership. UID/GID 1000 matches a typical
# single-user Linux install; check `id` on your host if unsure.
DEV_USER=change_me
DEV_UID=1000
DEV_GID=1000

# Absolute host path to the *primary* checkout's .git directory. The dev
# container bind-mounts this at the same path internally so that worktree
# .git pointer files (which reference the primary's .git via absolute host
# path) resolve from inside the container. When running the primary stack,
# set this to that stack's own .git; when running a worktree stack, set it
# to the primary checkout's .git (NOT the worktree's). Without this, `git`
# commands fail inside worktree dev containers.
PRIMARY_GIT_DIR=change_me

# --- Metro / Expo dev server ---
# Metro auto-detects a "LAN IP" to embed in bundle/asset URLs; inside the
# container it picks the docker bridge IP (172.x.x.x) which the phone can't
# reach. Set this to your host's LAN address so Metro embeds a reachable URL.
METRO_HOST=change_me

# Host port the Metro bundler binds on. The container always serves on 9097
# internally; this is the host-side mapping. Override only when running a
# parallel stack from a git worktree (see worktree section below).
METRO_PORT=9097

# --- pgAdmin (only used with `--profile tools`) ---
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin
PGADMIN_PORT=9754

# --- Running a second stack from a git worktree (optional) ---
# Compose derives container, network, and per-stack volume names from
# COMPOSE_PROJECT_NAME, which defaults to the directory basename. Sibling
# worktrees (e.g. `../irrigo-API-60/`) already get distinct project names for
# free — only set this explicitly if you want to override.
# COMPOSE_PROJECT_NAME=irrigo
#
# Host ports must not collide between parallel stacks. Suggested offsets:
#
#     Stack                   PORT    METRO_PORT    PGADMIN_PORT
#     Primary (irrigo/)       9753    9097          9754
#     Worktree #1             9853    9098          9854
#     Worktree #2             9953    9099          9954
#
# The shared `irrigo-gradle` and `irrigo-android` volumes are declared
# `external: true` and must be created once on the host before any stack
# (primary or worktree) boots:
#
#     docker volume create irrigo-gradle
#     docker volume create irrigo-android
