<?xml version="1.0" encoding="utf-8"?>
<!--
    Android Network Security Config (APP-63).

    Default policy: HTTPS only. Every destination must use TLS unless it's
    explicitly listed in a `domain-config` below.

    Permitted-cleartext list:
      - 192.168.2.100 — home LAN host running irrigo-api. The personal-use
        deployment doesn't run TLS; if the home server ever moves, edit
        this entry (Android's NSC has no CIDR support — IPs are matched as
        exact strings).

    Wired in via `expo-build-properties` from app.json. `expo prebuild`
    copies this file to `android/app/src/main/res/xml/` and adds
    `android:networkSecurityConfig="@xml/network_security_config"` to the
    release manifest. The committed copy under `android/app/src/main/res/`
    keeps the next `assembleRelease` working without a fresh prebuild.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">192.168.2.100</domain>
    </domain-config>
</network-security-config>
