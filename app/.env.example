# Irrigo app environment variables.
#
# Copy this file to `app/.env.local` and fill in any values you want to
# override at bundle time. Expo embeds `EXPO_PUBLIC_*` variables into the
# JS bundle, so they survive in release builds — never put secrets here.

# Base URL the typed API client targets. Must be reachable from the device
# running the app. For Expo Go on a phone, that's your host's LAN IP — the
# same address you set as `METRO_HOST` in the repo root's `.env`. Defaults
# to `http://localhost:9753` when unset, which only works in simulators.
# EXPO_PUBLIC_API_BASE_URL=http://192.168.x.x:9753
